#!/bin/bash
# Apache Maven Wrapper Script for Unix/Linux/Mac

DIRNAME=$(cd "$(dirname "$0")" && pwd)

if [ ! -f "$DIRNAME/.mvn/wrapper/maven-wrapper.jar" ]; then
    echo "Downloading Maven wrapper..."
    mkdir -p "$DIRNAME/.mvn/wrapper"
    curl -fsSL https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar -o "$DIRNAME/.mvn/wrapper/maven-wrapper.jar"
fi

java -classpath "$DIRNAME/.mvn/wrapper/maven-wrapper.jar" org.apache.maven.wrapper.MavenWrapperMain "$@"
